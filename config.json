{
  "name": "syntek-rust-security",
  "version": "1.1.1",
  "description": "Rust security tooling plugin for Claude Code",
  "pluginTools": [
    {
      "name": "cargo-tool",
      "description": "Extract Cargo project metadata and analyze dependencies",
      "script": "plugins/bin/cargo-tool",
      "commands": {
        "info": "Get project metadata from Cargo.toml",
        "deps": "Analyze dependency tree",
        "targets": "List build targets",
        "features": "List feature flags",
        "unsafe": "Count unsafe blocks in project"
      }
    },
    {
      "name": "rustc-tool",
      "description": "Detect Rust toolchain version and configuration",
      "script": "plugins/bin/rustc-tool",
      "commands": {
        "version": "Get rustc version",
        "target": "Get target triple",
        "channel": "Get release channel (stable/beta/nightly)",
        "sysroot": "Get sysroot path"
      }
    },
    {
      "name": "vuln-db-tool",
      "description": "Manage RustSec vulnerability database",
      "script": "plugins/bin/vuln-db-tool",
      "commands": {
        "update": "Update vulnerability database",
        "search": "Search for CVEs",
        "stats": "Get database statistics"
      }
    },
    {
      "name": "audit-tool",
      "description": "Orchestrate security audits using cargo-audit, cargo-deny, and cargo-geiger",
      "script": "plugins/bin/audit-tool",
      "commands": {
        "run": "Run comprehensive security audit",
        "quick": "Run quick security scan",
        "report": "Generate detailed security report"
      }
    },
    {
      "name": "fuzzer-tool",
      "description": "Manage fuzzing infrastructure (libfuzzer, AFL++, honggfuzz)",
      "script": "plugins/bin/fuzzer-tool",
      "commands": {
        "init": "Initialize fuzzing infrastructure",
        "run": "Start fuzzing campaign",
        "corpus": "Manage fuzzing corpus",
        "crashes": "Analyze crash dumps"
      }
    },
    {
      "name": "compliance-tool",
      "description": "Generate compliance reports (OWASP, CWE, CVSS)",
      "script": "plugins/bin/compliance-tool",
      "commands": {
        "owasp": "Generate OWASP compliance report",
        "cwe": "Map vulnerabilities to CWE categories",
        "cvss": "Calculate CVSS scores",
        "export": "Export reports to JSON/PDF/HTML"
      }
    }
  ],
  "agentConfiguration": {
    "defaultModel": "sonnet",
    "opusAgents": [
      "threat-model",
      "crypto-review",
      "pentest-tools",
      "gdpr-check",
      "refactor-code",
      "review-code",
      "minimize-unsafe",
      "design-api",
      "encrypt-setup",
      "server-harden",
      "ffi-audit",
      "ai-gateway-setup",
      "dpi-setup",
      "zeroize-audit",
      "threat-detection"
    ],
    "sonnetAgents": [
      "vuln-scan",
      "memory-audit",
      "fuzz-setup",
      "scan-secrets",
      "supply-chain-audit",
      "binary-check",
      "compliance-report",
      "version-bump",
      "generate-docs",
      "write-support-article",
      "git-workflow",
      "write-tests",
      "benchmark",
      "manage-deps",
      "vault-setup",
      "token-rotate",
      "ssh-wrapper",
      "cert-rotate",
      "cloudflare-setup",
      "docker-harden",
      "backup-setup",
      "firewall-setup",
      "ai-provider-add",
      "nginx-config",
      "gunicorn-config",
      "redis-config",
      "systemd-harden",
      "router-security-init",
      "nas-security-init",
      "homeserver-security-init",
      "gateway-security-init",
      "malware-scanner-setup",
      "ids-setup",
      "dns-proxy-setup",
      "threat-feeds-setup",
      "init"
    ]
  },
  "skillConfiguration": {
    "autoLoad": [
      "rust-security-core",
      "rust-crypto",
      "rust-embedded",
      "rust-web-security"
    ]
  },
  "paths": {
    "agents": "agents",
    "skills": "skills",
    "plugins": "plugins",
    "templates": "templates",
    "examples": "examples",
    "commands": "commands",
    "docs": "docs"
  },
  "integration": {
    "syntek-dev-suite": {
      "enabled": true,
      "sharedAgents": ["git", "version", "docs", "review", "test-writer"],
      "namespace": "rust-security"
    }
  },
  "security": {
    "sandboxPluginTools": true,
    "allowedCommands": [
      "cargo",
      "rustc",
      "rustup",
      "cargo-audit",
      "cargo-deny",
      "cargo-geiger",
      "cargo-fuzz",
      "cargo-semver-checks"
    ],
    "restrictedPaths": [
      "/etc",
      "/var",
      "/usr/bin",
      "/bin",
      "~/.ssh",
      "~/.aws"
    ]
  }
}
