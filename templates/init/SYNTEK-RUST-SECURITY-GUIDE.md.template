## Input Validation

### Validate All External Input

```rust
use thiserror::Error;

#[derive(Error, Debug)]
pub enum ValidationError {
    #[error("input too long: {0} bytes (max: {1})")]
    TooLong(usize, usize),
    #[error("invalid character at position {0}")]
    InvalidChar(usize),
    #[error("input cannot be empty")]
    Empty,
}

/// Validate and sanitize user input
pub fn validate_username(input: &str) -> Result<String, ValidationError> {
    const MAX_LEN: usize = 64;

    if input.is_empty() {
        return Err(ValidationError::Empty);
    }

    if input.len() > MAX_LEN {
        return Err(ValidationError::TooLong(input.len(), MAX_LEN));
    }

    for (i, c) in input.chars().enumerate() {
        if !c.is_alphanumeric() && c != '_' && c != '-' {
            return Err(ValidationError::InvalidChar(i));
        }
    }

    Ok(input.to_lowercase())
}
```

### Path Traversal Prevention

```rust
use std::path::{Path, PathBuf};

/// Safely join a user-provided path component
pub fn safe_path_join(base: &Path, user_input: &str) -> Result<PathBuf, Error> {
    // Reject absolute paths
    if Path::new(user_input).is_absolute() {
        return Err(Error::AbsolutePathNotAllowed);
    }

    // Reject path traversal attempts
    if user_input.contains("..") {
        return Err(Error::PathTraversalDetected);
    }

    let joined = base.join(user_input);
    let canonical = joined.canonicalize()?;

    // Verify result is still under base
    if !canonical.starts_with(base.canonicalize()?) {
        return Err(Error::PathTraversalDetected);
    }

    Ok(canonical)
}
```

