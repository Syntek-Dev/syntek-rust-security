## FFI Security

### Safe FFI Patterns

```rust
use std::ffi::{CStr, CString};
use std::os::raw::c_char;

/// Safe wrapper for C string operations
pub fn safe_c_string(rust_str: &str) -> Result<CString, Error> {
    CString::new(rust_str).map_err(|_| Error::NullByteInString)
}

/// Safe wrapper for receiving C strings
///
/// # Safety
///
/// The caller must ensure:
/// - `ptr` is a valid pointer to a null-terminated C string
/// - The string remains valid for the duration of this call
/// - The string contains valid UTF-8
pub unsafe fn from_c_string(ptr: *const c_char) -> Result<String, Error> {
    if ptr.is_null() {
        return Err(Error::NullPointer);
    }

    let c_str = CStr::from_ptr(ptr);
    c_str.to_str()
        .map(|s| s.to_owned())
        .map_err(|_| Error::InvalidUtf8)
}
```

