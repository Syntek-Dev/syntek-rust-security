## AppState Pattern

Share state across Axum handlers via `Arc<AppState>`. Use `axum::extract::State`
to extract it in handlers.

```rust
use std::sync::Arc;

pub struct AppState {
    pub users: Arc<dyn UserService>,
    pub config: Arc<Config>,
    // Add other shared services here
}

impl AppState {
    pub fn new(config: Config, pool: sqlx::PgPool) -> Arc<Self> {
        let user_repo = Arc::new(SqlxUserRepository { pool });
        let users = Arc::new(UserServiceImpl { repo: user_repo });

        Arc::new(AppState {
            users: users as Arc<dyn UserService>,
            config: Arc::new(config),
        })
    }
}

// In a handler:
pub async fn get_user(
    State(state): State<Arc<AppState>>,
    Path(id): Path<String>,
) -> Result<impl IntoResponse, ApiError> {
    let user_id = UserId::parse(&id).map_err(|_| ApiError::Validation {
        field: "id".to_string(),
        message: "invalid user ID format".to_string(),
    })?;
    let user = state.users.get_user(user_id).await?;
    Ok(Json(ApiResponse { data: user }))
}
```

