## Repository Pattern

Abstract database access behind a trait. The service layer depends on the
trait; the concrete implementation uses `sqlx` or another driver.

```rust
use async_trait::async_trait;

#[async_trait]
pub trait UserRepository: Send + Sync {
    async fn find_by_id(&self, id: UserId) -> Result<Option<User>, RepositoryError>;
    async fn save(&self, user: &User) -> Result<(), RepositoryError>;
    async fn delete(&self, id: UserId) -> Result<(), RepositoryError>;
}

pub struct SqlxUserRepository {
    pool: sqlx::PgPool,
}

#[async_trait]
impl UserRepository for SqlxUserRepository {
    async fn find_by_id(&self, id: UserId) -> Result<Option<User>, RepositoryError> {
        sqlx::query_as!(
            UserRow,
            "SELECT id, name, created_at FROM users WHERE id = $1 AND deleted_at IS NULL",
            id.0
        )
        .fetch_optional(&self.pool)
        .await
        .map_err(RepositoryError::Database)
        .map(|row| row.map(User::from))
    }

    // ...
}
```

